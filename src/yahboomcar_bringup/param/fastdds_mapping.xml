<?xml version="1.0" encoding="UTF-8" ?>
<profiles xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">
    <participant profile_name="mapping_participant" is_default_profile="true">
        <rtps>
            <allocation>
                <remote_locators>
                    <max_unicast_locators>4</max_unicast_locators>
                    <max_multicast_locators>1</max_multicast_locators>
                </remote_locators>
                <total_participants>
                    <initial>2</initial>
                    <maximum>12</maximum>
                </total_participants>
                <total_readers>
                    <initial>8</initial>
                    <maximum>48</maximum>
                </total_readers>
                <total_writers>
                    <initial>8</initial>
                    <maximum>48</maximum>
                </total_writers>
            </allocation>
        </rtps>
    </participant>
    <data_writer profile_name="mapping_writer" is_default_profile="true">
        <historyMemoryPolicy>PREALLOCATED_WITH_REALLOC</historyMemoryPolicy>
        <topic>
            <historyQos>
                <kind>KEEP_LAST</kind>
                <depth>5</depth>
            </historyQos>
        </topic>
    </data_writer>
    <data_reader profile_name="mapping_reader" is_default_profile="true">
        <historyMemoryPolicy>PREALLOCATED_WITH_REALLOC</historyMemoryPolicy>
        <topic>
            <historyQos>
                <kind>KEEP_LAST</kind>
                <depth>5</depth>
            </historyQos>
        </topic>
    </data_reader>
</profiles>
